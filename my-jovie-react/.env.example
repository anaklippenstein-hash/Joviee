# Server
PORT=5001
CLIENT_ORIGIN=http://localhost:5173

# Frontend API base (optional)
# Use empty for same-origin with Vite proxy, or full URL in production.
VITE_API_BASE=

# SMTP (example values)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Email routing
MAIL_FROM=your-email@example.com
MAIL_TO=where-you-want-to-receive@example.com
